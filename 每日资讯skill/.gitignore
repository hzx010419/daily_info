# ==============================================================
# 打包 / 版本控制忽略清单
# ==============================================================
# !!! 关键安全文件：发布给他人前务必排除 !!!
.machine_fingerprint

# 运行时产物
cache/
logs/
*.pyc
__pycache__/
src/__pycache__/

# 历史筛选记录（体积大且与代码无关，发布可选保留）
筛选记录/

# 系统文件
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# 输出文档目录（如果生成在 skill 内部）
output/

# 用户级凭证（理论上在 ~/.daily_news_skill/，不会出现在仓库里，但保险起见）
credentials.enc
